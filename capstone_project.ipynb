# Make copies to avoid modifying the original X_train and X_test
X_train_processed = X_train.copy()
X_test_processed = X_test.copy()

# Drop 'Property_ID' as it's an identifier and not numerical
X_train_processed = X_train_processed.drop('Property_ID', axis=1)
X_test_processed = X_test_processed.drop('Property_ID', axis=1)

# Apply one-hot encoding to 'Location' and 'Property_Type'
# drop_first=True avoids multicollinearity
X_train_processed = pd.get_dummies(X_train_processed, columns=['Location', 'Property_Type'], drop_first=True)
X_test_processed = pd.get_dummies(X_test_processed, columns=['Location', 'Property_Type'], drop_first=True)

# Ensure columns are aligned between train and test after one-hot encoding
# This is important if some categories appear in train but not test, or vice versa
train_cols = set(X_train_processed.columns)
test_cols = set(X_test_processed.columns)

missing_in_test = train_cols - test_cols
for c in missing_in_test:
    X_test_processed[c] = 0

missing_in_train = test_cols - train_cols
for c in missing_in_train:
    X_train_processed[c] = 0

# Reorder columns to ensure consistency
X_test_processed = X_test_processed[X_train_processed.columns]

model = LinearRegression()

model.fit(X_train_processed, y_train)
# Original input for numerical features (Area, Bedrooms, Bathrooms, Age)
new_house_numerical_features = [2000, 3, 2, 2] # Area, Bedrooms, Bathrooms, Age

# To make a prediction, the new house data must be in the same format
# as the training data (X_train_processed), which includes one-hot encoded columns.
# We need to specify the Location and Property_Type for the new house.
# Let's assume for this example:
new_house_location = 'City Center'
new_house_property_type = 'Apartment'

# Create a dictionary to hold all feature values for the new house
# Initialize with numerical features
new_house_data = {
    'Area': new_house_numerical_features[0],
    'Bedrooms': new_house_numerical_features[1],
    'Bathrooms': new_house_numerical_features[2],
    'Age': new_house_numerical_features[3]
}

# Get the list of all columns the model expects
model_features = X_train_processed.columns.tolist()

# Add one-hot encoded features, setting them to 0 initially
for feature in model_features:
    if feature not in new_house_data:
        new_house_data[feature] = 0

# Set the specific one-hot encoded columns based on assumed values
if f'Location_{new_house_location}' in model_features:
    new_house_data[f'Location_{new_house_location}'] = 1
if f'Property_Type_{new_house_property_type}' in model_features:
    new_house_data[f'Property_Type_{new_house_property_type}'] = 1

# Create a DataFrame for the new house, ensuring column order matches training data
new_house_df = pd.DataFrame([new_house_data], columns=model_features)

prediction = model.predict(new_house_df)

print("Predicted House Price:", prediction[0])
